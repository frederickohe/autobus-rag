# RAG stack environment (copy to .env on the server)
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
RAG_API_PORT=8088
QDRANT_URL=http://qdrant:6333
EMBEDDINGS_BASE_URL=http://embeddings:80
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5
RAG_COLLECTION_NAME=autobus_conversations
RAG_API_KEY=change-me-to-a-strong-secret
VECTOR_SIZE=384
LOG_LEVEL=info
